# ─────────────────────────────────────────────
#  RuangTV — Environment Configuration
#  Salin file ini ke .env dan sesuaikan nilainya.
#  JANGAN commit .env ke repository!
# ─────────────────────────────────────────────

# ── SERVER ──────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── WebSocket ───────────────────────────────
# URL publik server (digunakan oleh player.html untuk WS auto-detect)
# Contoh production: wss://ruangtv.ruangprint.id
# Biarkan kosong agar client auto-detect dari window.location
PUBLIC_URL=

# ── SECURITY ────────────────────────────────
# Secret untuk JWT / session (ganti dengan string acak ≥ 32 karakter)
SESSION_SECRET=changeme_use_random_32char_string

# ── RATE LIMITING ───────────────────────────
# Jumlah request maksimum per IP dalam window (menit)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── CORS ────────────────────────────────────
# Origins yang diizinkan, pisahkan dengan koma
# Contoh: https://admin.ruangprint.id,https://ruangtv.ruangprint.id
CORS_ORIGINS=http://localhost:3000

# ── LOGGING ─────────────────────────────────
# Pilihan: combined | dev | short | tiny | silent
LOG_FORMAT=dev

# ── CONTENT ─────────────────────────────────
# Direktori penyimpanan file konten (relatif terhadap root project)
CONTENT_DIR=./content
MAX_UPLOAD_SIZE_MB=200
